{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "node16",
    "target": "esnext",

    "rootDir": "./src",
    "outDir": "./dist",

    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "types": ["jest", "node"],
    "isolatedModules": true
  },
  "exclude": ["tests", "dist", "node_modules"]
}